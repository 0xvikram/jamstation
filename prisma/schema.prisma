datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String   @unique
  name           String?
  avatarUrl      String?
  voiceSampleUrl String?
  bio            String?
  createdAt      DateTime @default(now())

  // Onboarding fields
  onboardingCompleted Boolean @default(false)
  gender              String?
  musicalJourney      String?
  favoriteSinger      String?
  city                String?
  instagram           String?
  youtube             String?
  spotify             String?

  hostedSessions  Session[]      @relation("HostRelation")
  requests        StageRequest[]
  receivedRatings Rating[]       @relation("RatedUser")
  givenRatings    Rating[]       @relation("RatingAuthor")
}

model Session {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      SessionStatus @default(UPCOMING)
  entryFee    Float         @default(0)
  startTime   DateTime
  createdAt   DateTime      @default(now())

  hostId String
  host   User   @relation("HostRelation", fields: [hostId], references: [id])

  requests StageRequest[]
  ratings  Rating[]
}

model StageRequest {
  id        String        @id @default(uuid())
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
}

model Rating {
  id        String   @id @default(uuid())
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  ratedUserId String
  ratedUser   User   @relation("RatedUser", fields: [ratedUserId], references: [id])

  authorId String
  author   User   @relation("RatingAuthor", fields: [authorId], references: [id])

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
}

enum SessionStatus {
  UPCOMING
  LIVE
  ENDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
